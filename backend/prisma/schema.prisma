generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  fullName     String
  passwordHash String
  selectedPlan Plan     @default(free)
  pendingPlan  Plan?

  stripeCustomerId         String?  @map("stripeCustomerId")
  stripeSubscriptionId     String?  @map("stripeSubscriptionId")
  stripeSubscriptionStatus String?  @map("stripeSubscriptionStatus")
  stripeCurrentPeriodEnd   DateTime? @map("stripeCurrentPeriodEnd")

  roles    UserRole[]
  projects Project[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

enum Plan {
  free
  pro
  enterprise
}

enum Role {
  homeowner
  user
  contractor
  admin
  agent
}

model UserRole {
  id     String @id @default(cuid())
  userId String @unique
  role   Role

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("user_roles")
}

enum ProjectStatus {
  planning
  in_progress
  completed
}

model Project {
  id          String        @id @default(cuid())
  userId      String
  title       String
  description String?
  status      ProjectStatus @default(planning)
  budget      Float?        @default(0)
  progress    Int?          @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("projects")
}

